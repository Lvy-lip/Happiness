<view class="mission-page">
  <view class="top-nav">
    <view class="top-nav-title">成长打卡中心</view>
    <view class="top-nav-actions">
      <text class="top-nav-action" bindtap="onMoreTap">更多</text>
      <text class="top-nav-action" bindtap="onSettingsTap">设置</text>
    </view>
  </view>

  <view class="dashboard-card">
    <view class="dashboard-ring-wrap">
      <view class="dashboard-ring">
        <view class="dashboard-ring-inner">
          <text class="dashboard-ring-value">{{dashboard.completeRate}}%</text>
          <text class="dashboard-ring-label">完成率</text>
        </view>
      </view>
    </view>
    <view class="dashboard-stats">
      <view class="stat-item">
        <text class="stat-label">今日完成</text>
        <text class="stat-value">{{dashboard.todayFinished}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">今日积分</text>
        <text class="stat-value">+{{dashboard.todayPoints}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">连续打卡</text>
        <text class="stat-value">{{dashboard.streakDays}}天</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">预计剩余</text>
        <text class="stat-value">{{dashboard.remainMinutes}}m</text>
      </view>
    </view>
  </view>

  <view class="quick-actions">
    <view class="quick-action-card" data-action="new" bindtap="onQuickActionTap">
      <text class="quick-action-icon">➕</text>
      <text class="quick-action-text">新建任务</text>
    </view>
    <view class="quick-action-card" data-action="template" bindtap="onQuickActionTap">
      <text class="quick-action-icon">🧩</text>
      <text class="quick-action-text">计划模板</text>
    </view>
    <view class="quick-action-card" data-action="review" bindtap="onQuickActionTap">
      <text class="quick-action-icon">📝</text>
      <text class="quick-action-text">今日复盘</text>
    </view>
    <view class="quick-action-card" data-action="gallery" bindtap="onQuickActionTap">
      <text class="quick-action-icon">📷</text>
      <text class="quick-action-text">回忆馆</text>
    </view>
  </view>

  <view class="filter-card">
    <scroll-view class="filter-scroll" scroll-x="true" show-scrollbar="false">
      <view class="filter-row">
        <view
          wx:for="{{filterOptions}}"
          wx:key="key"
          class="filter-pill {{activeFilter === item.key ? 'filter-pill-active' : ''}}"
          data-key="{{item.key}}"
          bindtap="onFilterChange"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>
    <scroll-view class="filter-scroll" scroll-x="true" show-scrollbar="false">
      <view class="filter-row">
        <view
          wx:for="{{sortOptions}}"
          wx:key="key"
          class="filter-pill {{activeSort === item.key ? 'filter-pill-active' : ''}}"
          data-key="{{item.key}}"
          bindtap="onSortChange"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{allMissions.length === 0}}" class="empty-state-card">
    <image class="empty-image" src="Images/None.png" mode="aspectFit" />
    <text class="empty-title">暂无任务</text>
    <text class="empty-subtitle">点击右下角开始创建你的第一条任务</text>
  </view>

  <view class="task-sections" wx:if="{{allMissions.length > 0}}">
    <view class="task-section" wx:for="{{sectionList}}" wx:key="key" wx:for-item="section">
      <view class="section-header" data-key="{{section.key}}" bindtap="toggleSection">
        <view class="section-title-wrap">
          <text class="section-title">{{section.title}}</text>
          <text class="section-count">{{section.count}}</text>
        </view>
        <text class="section-fold">{{section.collapsed ? '展开' : '收起'}}</text>
      </view>

      <view wx:if="{{!section.collapsed}}">
        <view wx:if="{{section.tasks.length === 0}}" class="section-empty">当前筛选下暂无任务</view>

        <view
          wx:for="{{section.tasks}}"
          wx:key="_id"
          wx:for-item="task"
          wx:for-index="taskIndex"
          class="task-card {{task.available ? '' : 'task-card-completed'}}"
          data-id="{{task._id}}"
          bindtap="toDetailById"
        >
          <view class="task-left">
            <view class="task-title">{{task.title}}</view>
            <view class="task-desc">{{task.desc}}</view>
            <view class="task-meta-row">
              <text class="task-tag">{{task.timeTag}}</text>
              <text class="task-tag">{{task.typeTag}}</text>
              <text class="task-tag">{{task.priorityTag}}</text>
            </view>
            <view class="task-reward-row">
              <text class="task-reward">+{{task.credit}} 积分</text>
            </view>
          </view>

          <view class="task-right" catchtap="noop">
            <view
              class="task-complete-btn {{task.available ? '' : 'task-complete-btn-done'}}"
              data-id="{{task._id}}"
              bindtap="onTaskCompleteTap"
            >
              {{task.available ? '✓' : '已'}}
            </view>
            <view class="task-side-actions">
              <text class="task-side-action" data-id="{{task._id}}" bindtap="onToggleStar">星标</text>
              <text class="task-side-action task-side-action-remove" data-id="{{task._id}}" bindtap="onDeleteTask">删除</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="fab" bindtap="onFabTap">+</view>
</view>