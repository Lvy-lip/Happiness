.mission-page {
  min-height: 100vh;
  background: #f6f7f9;
  padding-bottom: 96px;
}

.top-nav {
  height: 88px;
  padding: 40px 16px 0;
  background: linear-gradient(135deg, #ffb5c8 0%, #ff8fae 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
}

.top-nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #ffffff;
}

.top-nav-actions {
  position: absolute;
  right: 16px;
  top: 44px;
  display: flex;
  align-items: center;
}

.top-nav-action {
  margin-left: 12px;
  font-size: 13px;
  color: rgba(255, 255, 255, 0.95);
}

.dashboard-card {
  margin: 16px;
  background: #ffffff;
  border-radius: 16px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  padding: 16px;
  display: flex;
  align-items: center;
}

.dashboard-ring-wrap {
  width: 112px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dashboard-ring {
  width: 92px;
  height: 92px;
  border-radius: 46px;
  border: 8px solid #ffd4df;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.dashboard-ring-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dashboard-ring-value {
  font-size: 18px;
  color: #22242a;
  font-weight: 700;
  line-height: 20px;
}

.dashboard-ring-label {
  margin-top: 2px;
  font-size: 11px;
  color: #8f96a1;
}

.dashboard-stats {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
}

.stat-item {
  width: 50%;
  margin-bottom: 10px;
  display: flex;
  flex-direction: column;
}

.stat-item:nth-last-child(-n+2) {
  margin-bottom: 0;
}

.stat-label {
  font-size: 12px;
  color: #8b919c;
  line-height: 16px;
}

.stat-value {
  margin-top: 3px;
  font-size: 16px;
  color: #1f2126;
  font-weight: 600;
  line-height: 20px;
}

.quick-actions {
  margin: 0 16px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.quick-action-card {
  width: calc((100% - 18px) / 4);
  border-radius: 14px;
  background: #ffffff;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
  padding: 12px 6px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.quick-action-icon {
  font-size: 18px;
  line-height: 20px;
}

.quick-action-text {
  margin-top: 6px;
  font-size: 12px;
  color: #4f5661;
}

.filter-card {
  margin: 0 16px 16px;
  padding: 12px;
  background: #ffffff;
  border-radius: 16px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
}

.filter-scroll {
  width: 100%;
}

.filter-scroll + .filter-scroll {
  margin-top: 10px;
}

.filter-row {
  display: inline-flex;
  align-items: center;
  min-width: 100%;
}

.filter-pill {
  height: 30px;
  padding: 0 12px;
  margin-right: 8px;
  border-radius: 15px;
  background: #ffffff;
  border: 1px solid #d9dde5;
  color: #5f6670;
  font-size: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-pill-active {
  background: #22242a;
  color: #ffffff;
  border-color: #22242a;
}

.empty-state-card {
  margin: 0 16px;
  border-radius: 16px;
  background: #ffffff;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  padding: 20px 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-image {
  width: 54vw;
  height: 24vh;
}

.empty-title {
  margin-top: 8px;
  font-size: 16px;
  color: #2d3037;
  font-weight: 600;
}

.empty-subtitle {
  margin-top: 6px;
  font-size: 12px;
  color: #8f96a1;
}

.task-sections {
  margin: 0 16px;
}

.task-section {
  border-radius: 16px;
  background: #ffffff;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  padding: 14px;
  margin-bottom: 16px;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-title {
  font-size: 16px;
  color: #1f2126;
  font-weight: 600;
}

.section-count {
  margin-left: 8px;
  min-width: 22px;
  height: 20px;
  line-height: 20px;
  border-radius: 10px;
  background: #f1f3f7;
  color: #66707f;
  text-align: center;
  font-size: 12px;
}

.section-fold {
  font-size: 12px;
  color: #8e95a0;
}

.section-empty {
  margin-top: 12px;
  border-radius: 12px;
  background: #f7f8fa;
  padding: 16px;
  font-size: 12px;
  color: #9aa1ac;
  text-align: center;
}

.task-card {
  margin-top: 12px;
  border-radius: 14px;
  background: #ffffff;
  border: 1px solid #eff2f5;
  padding: 12px;
  display: flex;
  justify-content: space-between;
  transition: all 0.2s ease;
}

.task-card-completed {
  background: #f2f4f7;
  border-color: #e6e9ee;
  padding-top: 8px;
  padding-bottom: 8px;
}

.task-card-completed .task-title {
  color: #9aa1ab;
  text-decoration: line-through;
}

.task-card-completed .task-desc,
.task-card-completed .task-tag,
.task-card-completed .task-reward {
  color: #a8afb9;
}

.task-left {
  flex: 1;
  min-width: 0;
}

.task-title {
  font-size: 15px;
  line-height: 20px;
  color: #23262d;
  font-weight: 600;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.task-desc {
  margin-top: 4px;
  font-size: 12px;
  line-height: 16px;
  color: #8f96a1;
}

.task-meta-row {
  margin-top: 8px;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.task-tag {
  height: 22px;
  line-height: 22px;
  border-radius: 20px;
  background: #f0f2f6;
  padding: 0 10px;
  font-size: 11px;
  color: #687180;
  margin-right: 6px;
  margin-bottom: 6px;
}

.task-reward-row {
  margin-top: 4px;
}

.task-reward {
  font-size: 13px;
  color: #ff6f9a;
  font-weight: 600;
}

.task-right {
  width: 70px;
  margin-left: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.task-complete-btn {
  width: 44px;
  height: 44px;
  border-radius: 22px;
  background: #22242a;
  color: #ffffff;
  font-size: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-complete-btn-done {
  background: #c4cad4;
  font-size: 13px;
}

.task-side-actions {
  margin-top: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.task-side-action {
  font-size: 11px;
  color: #6d7582;
  line-height: 18px;
}

.task-side-action-remove {
  color: #de7d8c;
}

.fab {
  position: fixed;
  right: 16px;
  bottom: 96px;
  width: 56px;
  height: 56px;
  border-radius: 28px;
  background: #22242a;
  color: #ffffff;
  font-size: 30px;
  line-height: 56px;
  text-align: center;
  box-shadow: 0 10px 28px rgba(0, 0, 0, 0.2);
}
