.memory-add-page {
  min-height: 100vh;
  background: #f7f7f7;
  padding: 16px;
  box-sizing: border-box;
}

.memory-add-card {
  background: #ffffff;
  border-radius: 16px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  padding: 16px;
}

.field {
  margin-bottom: 14px;
}

.label {
  display: block;
  font-size: 13px;
  color: #616978;
  margin-bottom: 6px;
}

.input,
.picker {
  height: 38px;
  border-radius: 10px;
  background: #f6f7fa;
  padding: 0 10px;
  font-size: 14px;
  color: #2a2f37;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  min-height: 84px;
  border-radius: 10px;
  background: #f6f7fa;
  padding: 10px;
  box-sizing: border-box;
  font-size: 14px;
  color: #2a2f37;
}

.pick-row {
  display: flex;
  align-items: center;
}

.pick-btn {
  margin-right: 10px;
  min-width: 72px;
  height: 32px;
  border-radius: 16px;
  background: #f1e8ee;
  color: #6a6070;
  font-size: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview {
  margin-top: 10px;
  width: 100%;
  height: 180px;
  border-radius: 12px;
}

.submit-btn {
  height: 40px;
  border-radius: 20px;
  background: #f58fa0;
  color: #ffffff;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}
