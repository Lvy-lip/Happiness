.banner-swiper { height: 280rpx; margin-top: 14rpx; }
.banner-image { width: 100%; height: 100%; border-radius: 20rpx; }
.title { font-weight: 600; color: #70576b; margin-bottom: 14rpx; }
.week-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12rpx; }
.day-item { background: #fff3f9; border-radius: 16rpx; padding: 14rpx 8rpx; text-align: center; }
.day-label { display:block; color:#9f7f93; font-size:22rpx; }
.day-rate { color:#ff7fb0; font-size:24rpx; font-weight:600; }
.point-row { color:#876d7a; }
.point-value { color:#ff6ba8; font-size:40rpx; font-weight:700; margin-left: 16rpx; }
